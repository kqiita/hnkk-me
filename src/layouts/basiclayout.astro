---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
    title: string;
    description?: string;
    pubDate?: Date;
    updDate?: Date;
}
const { title, description, pubDate, updDate } = Astro.props;
---

<!-- Home -->
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <title>{title}</title>
    </head>
    <body>
        <Header />
        <main>
            <div id="pubdate">
                {pubDate && <p>公開日 {pubDate?.toLocaleDateString()}</p>}
                {updDate && <p>{updDate?.toLocaleDateString()} 更新</p>}
            </div>
            <div id="content"><slot /></div>
        </main>
        <Footer />
    </body>
</html>
<style></style>
