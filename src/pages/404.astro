---
import Basiclayout from "@/layouts/basiclayout.astro";
import "@/styles/global.css";
---

<Basiclayout title="404 not found" description="404 not found">
    <div id="message">
        <h1>404 not found</h1>
        <a id="button-home" href="/"><div>ホームへ戻る</div></a>
    </div>
</Basiclayout>
<style>
    #message {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    #button-home {
        display: block;
        text-decoration: none;
        color: var(--sub-text-color);
        padding: 1rem 3rem;
        background-color: var(--sub-color);
        border: 4px solid var(--sub-bg-color);
        border-radius: 1rem;
    }
    #button-home:visited {
        color: var(--sub-text-color);
    }
    #button-home:hover {
        background-color: var(--sub-bg-color);
        border-color: var(--sub-color);
    }
</style>
